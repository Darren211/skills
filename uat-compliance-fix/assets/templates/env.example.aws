# ============================================
# AWS 凭证配置模板（.env.example 中与 AWS 相关部分）
# 安全要求：生产使用 IAM 角色；禁止在此填写真实 AK/SK
# ============================================

# 区域（可保留默认，生产由部署平台覆盖）
AWS_REGION=ap-east-1

# 生产/预发：使用 IAM 角色，不配置以下两项
# 本地开发：临时使用 aws configure 或 SSO，勿将真实值提交
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# 通过 AWS Secrets Manager 注入的配置名（运行时由平台设置）
# 应用启动时若 SECRET_NAME 非空，则从该 Secret 拉取 JSON 并合并到环境变量
SECRET_NAME=
